{
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "updateContentCommand": "npm install",
  "postAttachCommand": "npm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Dev Server",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
